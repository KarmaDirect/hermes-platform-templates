# syntax=docker/dockerfile:1.6
# =============================================================================
# Hermes Client Edition v1 — Dockerfile
# =============================================================================
# Builds a per-client Hermes instance from the upstream Nous Research base
# image, layering in our config templates, the 8 core skills, and a bootstrap
# script that renders configs from environment variables at first boot.
#
# Notes / TODOs:
#   - Base image tag `nousresearch/hermes-agent:v2026.4.30` (= v0.12.0, "Curator"
#     release, April 30 2026). Brings autonomous skill curation + plugin host
#     gateway + DeepSeek V4 on Nous Portal + cold start −57%. If the image is
#     private, the control-plane must `docker login` before build.
#   - Default UID/GID inside the upstream image is 1000:1000 (`hermes` user).
#     We chown our injected files to keep file ownership consistent.
#   - Real ENTRYPOINT/CMD of the base image is unconfirmed. We override with
#     bootstrap.sh which then exec's the server. Adjust SERVER_CMD below if
#     the upstream binary path changes.
# =============================================================================

# ---------- Stage 1 : assets ----------
# Tiny stage that just stages our template files so we can rsync/chown them
# onto the runtime image without bloating layer history.
FROM alpine:3.19 AS assets

WORKDIR /staging

# Copy template tree into staging
COPY config/   /staging/config/
COPY skills/   /staging/skills/
COPY bootstrap.sh /staging/bootstrap.sh

# Normalize line endings (Windows hosts often produce CRLF) + perms
RUN apk add --no-cache dos2unix \
 && find /staging -type f \( -name "*.sh" -o -name "*.yaml" -o -name "*.yml" -o -name "*.tpl" -o -name "*.md" \) -exec dos2unix {} + \
 && chmod +x /staging/bootstrap.sh \
 && find /staging -type d -exec chmod 0755 {} + \
 && find /staging -type f -exec chmod 0644 {} + \
 && chmod +x /staging/bootstrap.sh

# ---------- Stage 2 : runtime ----------
FROM nousresearch/hermes-agent:v2026.4.30

# Metadata
LABEL org.opencontainers.image.title="Hermes Client Edition v1"
LABEL org.opencontainers.image.description="Per-client Hermes instance for Hermes Platform SaaS"
LABEL org.opencontainers.image.vendor="Hermes Platform"
LABEL org.opencontainers.image.source="https://github.com/webstate/hermes-platform"

# We need a couple of small utilities for templating + healthcheck.
# The upstream image is debian-slim based (assumed). Adjust apt vs apk if not.
USER root
RUN set -eux; \
    if command -v apt-get >/dev/null 2>&1; then \
      apt-get update && apt-get install -y --no-install-recommends \
        gettext-base curl ca-certificates tini \
      && rm -rf /var/lib/apt/lists/*; \
    elif command -v apk >/dev/null 2>&1; then \
      apk add --no-cache gettext curl ca-certificates tini; \
    fi

# Sprint 3.1 — RTK plugin pour Hermès : compresse stdout shell de 60-90%.
# Le plugin Python `rtk-hermes` intercepte les appels au tool `terminal` et
# délègue à `rtk rewrite` pour optimiser. Source : ogallotti/rtk-hermes.
# Cf. memory:reference_hermes_repos_findings.md Sprint 3.
RUN set -eux; \
    curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh || true; \
    if [ -x /opt/hermes/.venv/bin/python ]; then \
      /opt/hermes/.venv/bin/python -m ensurepip --upgrade 2>/dev/null || true; \
      /opt/hermes/.venv/bin/python -m pip install --no-cache-dir rtk-hermes 2>/dev/null \
        || echo "[build] rtk-hermes pip install skipped (pip absent or install failed) — install at runtime"; \
    fi

# Pre-create the directory layout the runtime expects.
# /opt/hermes-template = pristine read-only assets shipped in the image.
# /data, /skills, /profiles = mounted volumes (writable, persisted).
RUN mkdir -p /opt/hermes-template/config \
             /opt/hermes-template/skills \
             /data \
             /skills \
             /profiles \
 && chown -R 1000:1000 /opt/hermes-template /data /skills /profiles

# Inject our staged template files
COPY --from=assets --chown=10000:10000 /staging/config/      /opt/hermes-template/config/
COPY --from=assets --chown=10000:10000 /staging/skills/      /opt/hermes-template/skills/
COPY --from=assets --chown=10000:10000 /staging/bootstrap.sh /usr/local/bin/bootstrap.sh

RUN chmod +x /usr/local/bin/bootstrap.sh

# Stay root: bootstrap.sh chowns the volumes then drops to hermes via gosu.
# Root is required at boot because Coolify-managed volumes are owned by root.
USER root

# Working directory used by Hermes server (assumed)
WORKDIR /home/hermes

# Ports
#   8642 -> Hermes FastAPI (skills HTTP + webhooks)
#   9119 -> optional internal Hermes admin/dashboard
EXPOSE 8642 9119

# Healthcheck. Bootstrap touches /data/.ready once channels + skills are loaded,
# THEN the FastAPI /health endpoint is the source of truth.
HEALTHCHECK --interval=30s --timeout=5s --start-period=45s --retries=5 \
  CMD curl -fsS http://127.0.0.1:9119/health >/dev/null || exit 1

# Use tini as PID 1 to handle signals + zombie reaping cleanly.
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/bootstrap.sh"]

# bootstrap.sh ends with `exec hermes serve ...` so no CMD needed.
# If the upstream binary name differs (e.g. `hermes-agent` or `python -m hermes`),
# update SERVER_CMD inside bootstrap.sh — NOT here.
