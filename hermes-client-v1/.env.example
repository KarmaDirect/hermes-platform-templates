# =============================================================================
# Hermes Client Edition v1 — .env.example
# =============================================================================
# Copy to `.env` and fill values. The control-plane injects these via Coolify
# at provisioning time, so manual editing is only needed for local debug.
# =============================================================================

# ---- Identité client -------------------------------------------------------
CLIENT_NAME="Bastide BTP"
CLIENT_SLUG="bastide-btp"            # lowercase, kebab-case, used as profile name + container suffix
CLIENT_VERTICAL="btp"                # btp | restauration | coiffure | medical | generic
CLIENT_BRAND_COLOR="#3b82f6"         # hex, used by Hermes for UI/PDF accents
CLIENT_TONE="pro"                    # pro | familier | technique | premium

# ---- Hermès auth (généré par le control-plane) -----------------------------
HERMES_API_TOKEN="hp_REPLACE_ME"

# ---- LLM providers ---------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# ---- Channels (laisser vide pour désactiver le channel) --------------------
VAPI_API_KEY=""
WHATSAPP_TOKEN=""
TELEGRAM_BOT_TOKEN=""
RESEND_API_KEY=""
INSTAGRAM_ACCESS_TOKEN=""

# ---- Skills à activer (séparés par virgules, sans espaces) -----------------
# Disponibles : reception-call, devis-vocal, devis-photo, relance-impayes,
#               suivi-chantier, posts-sociaux, compta-classement, briefing-quotidien
ENABLED_SKILLS="reception-call,devis-vocal,relance-impayes,briefing-quotidien"

# ---- Supabase Hermès Platform (write-back DB centrale) ---------------------
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---- Runtime ---------------------------------------------------------------
TZ="Europe/Paris"
LOG_LEVEL="info"                     # debug | info | warn | error
HERMES_HTTP_PORT="8642"              # exposed publicly via reverse proxy
HERMES_ADMIN_PORT="9119"             # bound to localhost only
HERMES_TEMPLATE_VERSION="v1"

# ---- Optional Paperclip ----------------------------------------------------
PAPERCLIP_API_TOKEN=""
PAPERCLIP_PORT="7777"
